# TRASSIR серверы (формат: TRASSIR_N_NAME, TRASSIR_N_HOST, TRASSIR_N_PORT, TRASSIR_N_USER, TRASSIR_N_PASSWORD)

# Сервер 1
TRASSIR_1_NAME=trassir-server1
TRASSIR_1_HOST=192.168.1.10
TRASSIR_1_PORT=8080
TRASSIR_1_USER=apiusr
TRASSIR_1_PASSWORD=your_password

# Сервер 2
TRASSIR_2_NAME=trassir-server2
TRASSIR_2_HOST=192.168.1.11
TRASSIR_2_PORT=8080
TRASSIR_2_USER=apiusr
TRASSIR_2_PASSWORD=your_password

# Общие настройки
SCRAPE_INTERVAL=60          # Интервал сбора метрик (секунды)
EXPORTER_PORT=8000          # Порт экспортера
TIMEOUT=10                  # Таймаут запросов к TRASSIR (секунды)
