# Example Prometheus configuration for TRASSIR exporter
# Copy to /etc/prometheus/prometheus.yml or include in your existing config

global:
  scrape_interval: 30s
  evaluation_interval: 15s

scrape_configs:
  # TRASSIR CCTV monitoring
  - job_name: 'trassir'
    scrape_interval: 60s
    scrape_timeout: 30s
    metrics_path: '/metrics'
    static_configs:
      - targets:
          - '10.10.64.100:8000'  # Замените на IP вашего экспортера
        labels:
          environment: 'production'
          service: 'cctv'
          type: 'trassir'
